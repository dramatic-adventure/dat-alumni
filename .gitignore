# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# deps
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example      # keep a template without secrets
!.env.production   # NEXT_PUBLIC_* vars only — no secrets

# hosting
.vercel/
.netlify/

# typescript
*.tsbuildinfo

.env
.env.*
.env.local
.env.*.local
!.env.production   # NEXT_PUBLIC_* vars only — no secrets

/generated/prisma

# Local sqlite (dev only)
/dev.db
*.db
*.db-journal
*.db-wal
*.db-shm

# macOS
.DS_Store
**/.DS_Store

# Netlify prod import file (never commit)
netlify.env

# Local CSV fallbacks — generated at runtime, never commit stale data
# loadCsv.ts writes these as a last-resort local cache; Netlify Blobs is the
# real production fallback so these files don't need to be in the repo.
public/fallback/*.csv

# logs
*.log
dev.log
service-account.json
.claude/

.next/
.next-local/
